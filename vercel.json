{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://scholarmate-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://scholarmate-backend-production.up.railway.app/media/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://scholarmate-backend-production.up.railway.app/static/:path*"
    },
    {
      "source": "/((?!api/|media/|static/|.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|map|json)).*)",
      "destination": "/index.html"
    }
  ]
}
