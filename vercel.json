{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",

  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://scholarmate-backend-production.up.railway.app/api/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "https://scholarmate-backend-production.up.railway.app/media/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "https://scholarmate-backend-production.up.railway.app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
